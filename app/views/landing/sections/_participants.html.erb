<section class="participants">
  <div class="participants__star-bg">
    <img src="<%= image_url("landing/done-before/star-bg.png") %>" aria-hidden="true" alt="">
  </div>

  <h2 class="participants__title">What past participants say</h2>

  <div class="participants__cards">
    <div class="participants__card">
      <div class="participants__card-box participants__card-box--testimonial">
        <img src="<%= image_url("landing/done-before/participant-photo.png") %>" class="participants__card-photo" alt="Participant photo">
        <p class="participants__card-quote">I found a community of teens working on incredible projects, which helped me out of my comfort zone, from just software to even hardware and automation.</p>
      </div>
      <div class="participants__card-star-wrap">
        <img src="<%= image_url("landing/done-before/star-deco-card.svg") %>" class="participants__card-star" aria-hidden="true" alt="">
        <div class="participants__card-info">
          <span class="participants__card-desc">15 year old high schooler from Japan</span>
        </div>
      </div>
    </div>

    <div class="participants__card">
      <div class="participants__card-box">
        <span class="participants__card-placeholder">Project</span>
      </div>
      <div class="participants__card-star-wrap">
        <img src="<%= image_url("landing/done-before/star-deco-card.svg") %>" class="participants__card-star" aria-hidden="true" alt="">
        <div class="participants__card-info">
          <span class="participants__card-desc">15 year old high schooler from Japan</span>
        </div>
      </div>
    </div>

    <div class="participants__card">
      <div class="participants__card-box">
        <span class="participants__card-placeholder">Project</span>
      </div>
      <div class="participants__card-star-wrap">
        <img src="<%= image_url("landing/done-before/star-deco-card.svg") %>" class="participants__card-star" aria-hidden="true" alt="">
        <div class="participants__card-info">
          <span class="participants__card-desc">15 year old high schooler from Japan</span>
        </div>
      </div>
    </div>
  </div>
</section>
