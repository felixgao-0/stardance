<% content_for :title, "Home" %>
<% content_for :twitter_card, "summary_large_image" %>
<% content_for :og_image, og_image_url('home', format: :png) %>

<%= content_for :stylesheets do %>
  <%= stylesheet_link_tag "landing", "data-turbo-track": "reload" %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Exo+2:ital,wght@0,400;0,700;1,400&family=Playfair+Display:ital,wght@1,700&display=swap" rel="stylesheet">
<% end %>

<%= render "landing/sections/header" %>
<%= render "landing/sections/hero" %>

<%= render "landing/sections/project_thumbnails" %>

<%= render "landing/sections/how_this_works" %>

<%= render "landing/sections/prizes" %>

<%= render "landing/sections/what_is_this" %>

<%= render "landing/sections/done_before" %>

<%= render "landing/sections/participants" %>

<%= render "landing/sections/faq" %>

<%= render "landing/sections/cta" %>

<%= render "landing/sections/footer" %>
